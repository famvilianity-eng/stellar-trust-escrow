// Prisma Schema — StellarTrustEscrow
//
// Run `npx prisma migrate dev` to create tables.
// Run `npx prisma generate` to regenerate the Prisma Client.
//
// TODO (contributor — medium, Issue #29):
// Review and finalize this schema. Consider:
// - Adding indexes for frequent query patterns (address lookups, status filters)
// - Adding created_at/updated_at to all tables (or using a Prisma plugin)
// - Whether dispute details need a separate table

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pool tuning via URL params:
  //   connection_limit — max connections per Prisma instance (default: num_cpus * 2 + 1)
  //   pool_timeout     — seconds to wait for a free connection (default: 10)
  //   connect_timeout  — seconds to establish a new connection (default: 5)
  // Example: postgresql://user:pass@host/db?connection_limit=20&pool_timeout=10
  // Set DB_POOL_CONNECTION_LIMIT / DB_POOL_TIMEOUT in env and embed in DATABASE_URL.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Tenants ───────────────────────────────────────────────────────────────────

model Tenant {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  status        String   @default("active")
  domains       String[] @default([])
  branding      Json?
  configuration Json?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  users                User[]
  escrows              Escrow[]
  milestones           Milestone[]
  reputationRecords    ReputationRecord[]
  reputationEvents     ReputationEvent[]
  disputes             Dispute[]
  disputeEvidence      DisputeEvidence[]
  disputeAppeals       DisputeAppeal[]
  userProfiles         UserProfile[]
  contractEvents       ContractEvent[]
  webhookSubscriptions WebhookSubscription[]
  payments             Payment[]
  kycVerifications     KycVerification[]
  adminAuditLogs       AdminAuditLog[]
  auditLogs            AuditLog[]
  chatRoomKeys         ChatRoomKey[]
  chatMessages         ChatMessage[]

  @@map("tenants")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id            Int      @id @default(autoincrement())
  tenantId      String   @map("tenant_id")
  email         String   @unique
  password      String
  walletAddress String?  @unique @map("wallet_address")
  role          String   @default("user") // user | admin | superadmin
  mfaEnabled    Boolean  @default(false) @map("mfa_enabled")
  mfaEnforced   Boolean  @default(false) @map("mfa_enforced") // Force MFA for high-value operations
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  refreshTokens RefreshToken[]
  mfaMethods    MfaMethod[]
  mfaAttempts   MfaAttempt[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, email])
  @@index([walletAddress])
  @@index([role])
  @@map("users")
}

// ── MFA Methods ───────────────────────────────────────────────────────────────

model MfaMethod {
  id        String  @id @default(cuid())
  userId    Int     @map("user_id")
  tenantId  String  @map("tenant_id")
  type      MfaType // TOTP | WEBAUTHN
  name      String // User-friendly name (e.g., "iPhone 15", "Authenticator App")
  isActive  Boolean @default(true) @map("is_active")
  isPrimary Boolean @default(false) @map("is_primary")

  // TOTP-specific fields
  totpSecret      String?  @map("totp_secret") // Encrypted TOTP secret
  totpBackupCodes String[] @default([]) @map("totp_backup_codes") // Encrypted backup codes

  // WebAuthn-specific fields
  credentialId String?  @unique @map("credential_id") // Base64-encoded credential ID
  publicKey    String?  @map("public_key") // Base64-encoded public key
  counter      BigInt?  @default(0) // Signature counter for replay protection
  transports   String[] @default([]) // usb, nfc, ble, internal
  aaguid       String? // Authenticator AAGUID

  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId])
  @@index([userId, isActive])
  @@index([type, isActive])
  @@index([credentialId])
  @@map("mfa_methods")
}

// ── MFA Attempts (Brute-force Protection) ─────────────────────────────────────

model MfaAttempt {
  id            String   @id @default(cuid())
  userId        Int      @map("user_id")
  tenantId      String   @map("tenant_id")
  methodType    MfaType  @map("method_type")
  success       Boolean
  ipAddress     String   @map("ip_address")
  userAgent     String?  @map("user_agent")
  failureReason String?  @map("failure_reason")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, success, createdAt(sort: Desc)])
  @@index([ipAddress, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("mfa_attempts")
}

// ── MFA Lockouts ──────────────────────────────────────────────────────────────

model MfaLockout {
  id          String   @id @default(cuid())
  userId      Int      @unique @map("user_id")
  tenantId    String   @map("tenant_id")
  lockedUntil DateTime @map("locked_until")
  reason      String   @default("Too many failed MFA attempts")
  attempts    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId, lockedUntil])
  @@index([lockedUntil])
  @@map("mfa_lockouts")
}

enum MfaType {
  TOTP
  WEBAUTHN
}

// ── Refresh Tokens ─────────────────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(cuid())
  userId     Int       @map("user_id")
  tenantId   String    @map("tenant_id")
  tokenHash  String    @unique @map("token_hash")
  deviceInfo Json?     @map("device_info")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime  @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, tenantId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@index([isActive])
  @@map("refresh_tokens")
}

// ── Escrows ───────────────────────────────────────────────────────────────────

model Escrow {
  /// On-chain escrow_id from the contract.
  /// Monthly archive partitions are materialized in escrows_archive_<YYYY_MM>
  /// and searched through the archive fallback path when live rows are exhausted.
  id                BigInt       @id
  tenantId          String       @map("tenant_id")
  clientAddress     String       @map("client_address")
  freelancerAddress String       @map("freelancer_address")
  arbiterAddress    String?      @map("arbiter_address")
  tokenAddress      String       @map("token_address")
  totalAmount       String       @map("total_amount") // BigInt stored as string
  remainingBalance  String       @map("remaining_balance")
  status            EscrowStatus
  briefHash         String       @map("brief_hash") // IPFS / content hash
  deadline          DateTime?
  createdAt         DateTime     @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  /// Stellar ledger sequence when this escrow was created
  createdLedger     BigInt       @map("created_ledger")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  milestones Milestone[]
  dispute    Dispute?

  @@index([tenantId])
  @@index([tenantId, clientAddress])
  @@index([tenantId, freelancerAddress])
  @@index([tenantId, status])
  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, clientAddress, createdAt(sort: Desc)])
  @@index([tenantId, freelancerAddress, createdAt(sort: Desc)])
  @@index([clientAddress])
  @@index([freelancerAddress])
  @@index([status])
  // Composite index for filtered + sorted list queries
  @@index([status, createdAt(sort: Desc)])
  // Composite index for user profile / user escrows OR queries
  @@index([clientAddress, createdAt(sort: Desc)])
  @@index([freelancerAddress, createdAt(sort: Desc)])
  // Composite index for user escrows with status filter
  @@index([clientAddress, status])
  @@index([freelancerAddress, status])
  // Composite index for user escrows with status filter + sort (covers getUserEscrows role+status queries)
  @@index([clientAddress, status, createdAt(sort: Desc)])
  @@index([freelancerAddress, status, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("escrows")
}

// ── Milestones ────────────────────────────────────────────────────────────────

model Milestone {
  id              Int             @id @default(autoincrement())
  tenantId        String          @map("tenant_id")
  /// on-chain milestone index within the escrow
  milestoneIndex  Int             @map("milestone_index")
  escrowId        BigInt          @map("escrow_id")
  title           String
  descriptionHash String          @map("description_hash")
  amount          String // BigInt as string
  status          MilestoneStatus
  submittedAt     DateTime?       @map("submitted_at")
  resolvedAt      DateTime?       @map("resolved_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  escrow Escrow @relation(fields: [escrowId], references: [id])

  @@unique([escrowId, milestoneIndex])
  @@index([tenantId, escrowId])
  @@index([tenantId, status])
  @@index([escrowId])
  @@index([status])
  @@map("milestones")
}

// ── Reputation ────────────────────────────────────────────────────────────────

model ReputationRecord {
  tenantId         String   @map("tenant_id")
  address          String   @id
  totalScore       BigInt   @default(0) @map("total_score")
  completedEscrows Int      @default(0) @map("completed_escrows")
  disputedEscrows  Int      @default(0) @map("disputed_escrows")
  disputesWon      Int      @default(0) @map("disputes_won")
  totalVolume      String   @default("0") @map("total_volume") // BigInt as string
  lastUpdated      DateTime @map("last_updated")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  events ReputationEvent[]

  @@index([tenantId, address])
  @@index([tenantId, totalScore(sort: Desc)])
  @@index([totalScore(sort: Desc)])
  @@map("reputation_records")
}

// ── Reputation Events (Audit & Recalculation) ──────────────────────────────────

enum ReputationEventType {
  ESCROW_COMPLETED
  DISPUTE_WON
  DISPUTE_LOST
  CANCELLATION
}

model ReputationEvent {
  id            String                 @id @default(cuid())
  tenantId      String                 @map("tenant_id")
  address       String
  eventType     ReputationEventType    @map("event_type")
  escrowId      BigInt?                @map("escrow_id")
  scoreDelta    Int                    @map("score_delta")
  createdAt     DateTime               @default(now()) @map("created_at")

  reputationRecord ReputationRecord @relation(fields: [address], references: [address])
  tenant           Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([address, eventType, escrowId])
  @@index([tenantId, address, createdAt(sort: Desc)])
  @@index([address, eventType])
  @@map("reputation_events")
}

// ── Disputes ─────────────────────────────────────────────────────────────────

model Dispute {
  id               Int       @id @default(autoincrement())
  tenantId         String    @map("tenant_id")
  escrowId         BigInt    @unique @map("escrow_id")
  raisedByAddress  String    @map("raised_by_address")
  raisedAt         DateTime  @map("raised_at")
  resolvedAt       DateTime? @map("resolved_at")
  /// Amount returned to client on resolution
  clientAmount     String?   @map("client_amount")
  /// Amount sent to freelancer on resolution
  freelancerAmount String?   @map("freelancer_amount")
  /// Address that resolved the dispute (arbiter, admin, or "system")
  resolvedBy       String?   @map("resolved_by")
  /// Outcome description
  resolution       String?
  /// AUTO | MANUAL | ESCALATED
  resolutionType   String?   @map("resolution_type")
  /// Whether this dispute was auto-resolved
  autoResolved     Boolean   @default(false) @map("auto_resolved")

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  escrow   Escrow            @relation(fields: [escrowId], references: [id])
  evidence DisputeEvidence[]
  appeals  DisputeAppeal[]

  @@index([tenantId, raisedByAddress])
  @@index([tenantId, resolvedAt])
  @@index([raisedByAddress])
  // Index for resolved/unresolved filtering (admin panel)
  @@index([resolvedAt])
  // Composite index for listing disputes sorted by raisedAt with resolution filter
  @@index([resolvedAt, raisedAt(sort: Desc)])
  @@map("disputes")
}

model DisputeEvidence {
  id           Int      @id @default(autoincrement())
  tenantId     String   @map("tenant_id")
  disputeId    Int      @map("dispute_id")
  submittedBy  String   @map("submitted_by")
  /// client | freelancer | arbiter | admin
  role         String
  /// text | url | hash | file | image
  evidenceType String   @map("evidence_type")
  content      String
  description  String?
  /// Original filename
  filename     String?
  /// File MIME type
  mimeType     String?  @map("mime_type")
  /// File size in bytes
  fileSize     Int?     @map("file_size")
  /// IPFS CID for file storage
  ipfsCid      String?  @map("ipfs_cid")
  /// IPFS CID for thumbnail (images only)
  thumbnailCid String?  @map("thumbnail_cid")
  /// SHA-256 hash of the file content (hex)
  fileHash     String?  @map("file_hash")
  /// Merkle root of all evidence files in this dispute batch
  merkleRoot   String?  @map("merkle_root")
  /// Virus scan status: pending | clean | infected | error
  scanStatus   String?  @default("pending") @map("scan_status")
  /// Virus scan result details
  scanResult   String?  @map("scan_result")
  submittedAt  DateTime @default(now()) @map("submitted_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  dispute Dispute @relation(fields: [disputeId], references: [id])

  @@index([tenantId, disputeId])
  @@index([tenantId, submittedBy])
  @@index([disputeId])
  @@index([submittedBy])
  @@index([ipfsCid])
  @@map("dispute_evidence")
}

model DisputeAppeal {
  id          Int       @id @default(autoincrement())
  tenantId    String    @map("tenant_id")
  disputeId   Int       @map("dispute_id")
  appealedBy  String    @map("appealed_by")
  reason      String
  status      String    @default("pending")
  reviewedBy  String?   @map("reviewed_by")
  reviewNotes String?   @map("review_notes")
  createdAt   DateTime  @default(now()) @map("created_at")
  resolvedAt  DateTime? @map("resolved_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  dispute Dispute @relation(fields: [disputeId], references: [id])

  @@index([tenantId, disputeId])
  @@index([tenantId, status])
  @@index([disputeId])
  @@index([status])
  @@map("dispute_appeals")
}

// ── Contract Events ───────────────────────────────────────────────────────────

model UserProfile {
  tenantId    String   @map("tenant_id")
  address     String   @id
  displayName String?  @map("display_name")
  bio         String?
  avatarUrl   String?  @map("avatar_url")
  preferences Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, address])
  @@index([tenantId, updatedAt(sort: Desc)])
  @@map("user_profiles")
}

/// Indexed record of every Soroban contract event emitted by the escrow contract.
/// Enables historical queries and real-time subscriptions without hitting the chain.
model ContractEvent {
  id         Int      @id @default(autoincrement())
  tenantId   String   @map("tenant_id")
  /// Stellar ledger sequence this event was emitted in
  ledger     BigInt
  /// Ledger close timestamp
  ledgerAt   DateTime @map("ledger_at")
  /// Contract address that emitted the event
  contractId String   @map("contract_id")
  /// Short event name derived from topic[0] (e.g. "esc_crt", "mil_apr")
  eventType  String   @map("event_type")
  /// Escrow ID extracted from topic[1] (null for contract-wide events)
  escrowId   BigInt?  @map("escrow_id")
  /// Full JSON-serialised topic array
  topics     Json
  /// Full JSON-serialised data payload
  data       Json
  /// Unique transaction hash + event index to prevent duplicate inserts
  txHash     String   @map("tx_hash")
  eventIndex Int      @map("event_index")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, txHash, eventIndex])
  @@index([tenantId, eventType])
  @@index([tenantId, escrowId])
  @@index([tenantId, ledgerAt(sort: Desc)])
  @@index([eventType])
  @@index([escrowId])
  @@index([ledger])
  @@index([ledgerAt(sort: Desc)])
  // Composite index for escrow-specific event queries with type filter
  @@index([escrowId, eventType])
  @@index([escrowId, ledgerAt(sort: Asc)])
  @@map("contract_events")
}

model WebhookSubscription {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  url        String
  secret     String
  eventTypes String[] @default([])
  isActive   Boolean  @default(true) @map("is_active")
  createdBy  String?  @map("created_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]
  tenant     Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdBy])
  @@map("webhook_subscriptions")
}

model WebhookDelivery {
  id             String    @id @default(cuid())
  subscriptionId String    @map("subscription_id")
  eventType      String    @map("event_type")
  payload        Json
  status         String    @default("pending")
  attempts       Int       @default(0)
  responseCode   Int?      @map("response_code")
  errorMessage   String?   @map("error_message")
  lastAttemptAt  DateTime? @map("last_attempt_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([eventType])
  @@map("webhook_deliveries")
}

// ── Indexer State ─────────────────────────────────────────────────────────────

/// Tracks the last ledger processed so the indexer can resume after restart.
model IndexerState {
  id                  Int    @id @default(1)
  lastProcessedLedger BigInt @default(0) @map("last_processed_ledger")

  @@map("indexer_state")
}

// ── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                  String        @id @default(cuid())
  tenantId            String        @map("tenant_id")
  address             String // Stellar address of payer
  escrowId            BigInt?       @map("escrow_id") // linked escrow (nullable until funded)
  stripeSessionId     String?       @unique @map("stripe_session_id")
  stripePaymentIntent String?       @unique @map("stripe_payment_intent")
  amountFiat          Int           @map("amount_fiat") // in cents (USD)
  amountCrypto        String?       @map("amount_crypto") // XLM/USDC amount after conversion
  currency            String        @default("usd")
  status              PaymentStatus @default(Pending)
  refundId            String?       @map("refund_id") // Stripe refund ID
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, address])
  @@index([tenantId, status])
  @@index([tenantId, address, createdAt(sort: Desc)])
  @@index([address])
  @@index([status])
  // Composite index for address lookups sorted by date
  @@index([address, createdAt(sort: Desc)])
  @@map("payments")
}

// ── KYC ──────────────────────────────────────────────────────────────────────

model KycVerification {
  id           Int       @id @default(autoincrement())
  tenantId     String    @map("tenant_id")
  address      String    @unique
  applicantId  String?   @unique @map("applicant_id") // Sumsub applicant ID
  status       KycStatus @default(Pending)
  reviewResult String?   @map("review_result") // approved | declined
  rejectLabels String[]  @map("reject_labels") // Sumsub rejection reasons
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, address])
  @@index([tenantId, status])
  @@index([status])
  @@map("kyc_verifications")
}

// ── Admin Audit Log ───────────────────────────────────────────────────────────

/// Immutable record of every admin action for accountability and audit trails.
model AdminAuditLog {
  id            Int      @id @default(autoincrement())
  tenantId      String   @map("tenant_id")
  /// Action taken, e.g. SUSPEND_USER, BAN_USER, RESOLVE_DISPUTE
  action        String
  /// The address or resource the action was taken against
  targetAddress String   @map("target_address")
  /// Human-readable reason supplied by the admin
  reason        String   @default("")
  /// Identifier of the admin who performed the action
  performedBy   String   @map("performed_by")
  performedAt   DateTime @map("performed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, action])
  @@index([tenantId, targetAddress])
  @@index([tenantId, performedAt(sort: Desc)])
  @@index([action])
  @@index([targetAddress])
  @@index([performedAt(sort: Desc)])
  @@map("admin_audit_logs")
}

// ── Audit Log ─────────────────────────────────────────────────────────────────

/// Comprehensive, append-only audit trail for all system events.
/// Records are never updated or deleted — retention is handled by archiving.
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  tenantId   String   @map("tenant_id")
  /// Category: AUTH | ESCROW | MILESTONE | DISPUTE | ADMIN | PAYMENT | KYC
  category   String
  /// Specific action, e.g. LOGIN, CREATE_ESCROW, APPROVE_MILESTONE
  action     String
  /// Actor performing the action (Stellar address or "system" / "admin")
  actor      String
  /// Primary resource identifier (escrow id, address, dispute id, etc.)
  resourceId String?  @map("resource_id")
  /// Snapshot of relevant state at the time of the event (JSON)
  metadata   Json?
  /// HTTP status code or outcome code
  statusCode Int?     @map("status_code")
  /// Client IP address
  ipAddress  String?  @map("ip_address")
  /// Immutable timestamp — set once on insert, never changed
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, category])
  @@index([tenantId, actor])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([category])
  @@index([action])
  @@index([actor])
  @@index([resourceId])
  @@index([createdAt(sort: Desc)])
  // Composite indexes for common admin filter combinations
  @@index([category, action])
  @@index([category, createdAt(sort: Desc)])
  @@index([actor, createdAt(sort: Desc)])
  @@map("audit_logs")
}

enum EscrowStatus {
  Active
  Completed
  Disputed
  Cancelled
}

enum MilestoneStatus {
  Pending
  Submitted
  Approved
  Rejected
}

// ── Feature Flags ─────────────────────────────────────────────────────────────

model FeatureFlag {
  key         String   @id
  isEnabled   Boolean  @default(false) @map("is_enabled")
  percentage  Int      @default(0)
  targetUsers String[] @default([]) @map("target_users")
  description String   @default("")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

enum KycStatus {
  Pending
  Init
  Processing
  Approved
  Declined
}

enum PaymentStatus {
  Pending
  Processing
  Completed
  Failed
  Refunded
}

// ── Chat (Encrypted Dispute Messaging) ───────────────────────────────────────
// roomId convention: "dispute:<escrowId>"
// encryptedKey: AES-256 session key wrapped with recipient's Stellar public key (ECIES).
// The server stores but never decrypts — plaintext never touches the backend.

/// Per-participant AES session key for a dispute chat room.
/// @@unique([roomId, address]) allows key rotation via upsert.
model ChatRoomKey {
  id           String   @id @default(cuid())
  roomId       String   @map("room_id")
  address      String
  /// AES-256 session key encrypted with recipient's Stellar public key (ECIES), base64-encoded
  encryptedKey String   @map("encrypted_key") @db.Text
  tenantId     String   @map("tenant_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([roomId, address])
  @@index([roomId])
  @@index([tenantId, roomId])
  @@map("chat_room_keys")
}

/// Encrypted message in a dispute chat room.
/// ciphertext/iv/tag: AES-256-GCM encrypted payload — server never decrypts.
model ChatMessage {
  id            String   @id @default(cuid())
  roomId        String   @map("room_id")
  senderAddress String   @map("sender_address")
  /// AES-256-GCM ciphertext, base64-encoded
  ciphertext    String   @db.Text
  /// 12-byte GCM nonce, base64-encoded
  iv            String   @db.Text
  /// 16-byte GCM auth tag, base64-encoded
  tag           String   @db.Text
  tenantId      String   @map("tenant_id")
  sentAt        DateTime @default(now()) @map("sent_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([roomId, sentAt])
  @@index([tenantId, roomId])
  @@map("chat_messages")
}
